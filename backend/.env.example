# ─── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurantos
DB_USER=postgres
DB_PASSWORD=your_db_password

# ─── JWT ───────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=another_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Upload ────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Cloudinary image storage (required in development and production)
# Prefer CLOUDINARY_URL from Cloudinary dashboard:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set all three values:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=restaurantos
