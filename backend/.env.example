# ─── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ────────────────────────────
DB_MODE=local
DATABASE_URL=
NEON_DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurantos
DB_USER=postgres
DB_PASSWORD=your_db_password

# ─── JWT ───────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=another_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Upload ────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Cloudinary image storage (required in development and production)
# Prefer CLOUDINARY_URL from Cloudinary dashboard:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set all three values:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=restaurantos

# ─── Local Offline Sync ───────────────────────────────────────────────────────
# Local restaurant server mode:
# DEPLOYMENT_MODE=local_offline
# DEVICE_ID=LOCAL-POS-01
# BRANCH_CODE=MAIN
# CLOUD_API_URL=https://your-railway-backend-url
# Set the same token on the local server and Railway backend.
# CLOUD_SYNC_TOKEN=change_this_to_a_long_random_sync_token
# Local worker pulls cloud master data every 60 seconds by default.
# MASTER_SYNC_PULL_INTERVAL_MS=60000
# Local menu image cache for offline mode.
# OFFLINE_IMAGE_CACHE_LIMIT=500
# OFFLINE_IMAGE_FETCH_TIMEOUT_MS=15000
