# ─── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database Selection ─────────────────────
# Set DB_MODE to "local" or "neon"
DB_MODE=neon

# ─── Local PostgreSQL ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurantos
DB_USER=postgres
DB_PASSWORD=mawgif7414

# ─── Neon (Cloud) PostgreSQL ─────────────────
DATABASE_URL=postgresql://neondb_owner:npg_2ojXp7PgJNAU@ep-withered-dust-anhdgci7-pooler.c-6.us-east-1.aws.neon.tech/restaurantos?sslmode=require&channel_binding=require

# ─── JWT ───────────────────────────────────
JWT_SECRET=restaurantos_jwt_secret_change_in_production_min32chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=restaurantos_refresh_secret_change_in_production_32c
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Upload ────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ─── Docker (set if PostgreSQL runs in Docker) ──────────────────────────────
# Run `docker ps` to find your container name
POSTGRES_CONTAINER=postgres-DB
