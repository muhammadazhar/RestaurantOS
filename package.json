{
  "name": "restaurantos",
  "version": "1.0.0",
  "description": "RestaurantOS — SaaS Restaurant Management Platform",
  "scripts": {
    "install:all":    "npm install --prefix backend && npm install --prefix frontend",
    "setup:db":       "npm run migrate --prefix backend && npm run seed --prefix backend",
    "dev:backend":    "npm run dev --prefix backend",
    "dev:frontend":   "npm start --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "start:backend":  "npm start --prefix backend",
    "start":          "npm install --prefix backend && node backend/src/index.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  }
}
