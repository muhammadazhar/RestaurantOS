# ── Backend URL (used for Socket.IO AND image src paths) ─────────────────────
# This must point to your Node.js backend.
REACT_APP_SOCKET_URL=http://localhost:5000

# ── API URL ──────────────────────────────────────────────────────────────────
# Leave this UNSET so Axios uses relative /api URL.
# React dev server proxy (package.json "proxy": "http://localhost:5000")
# will forward all /api requests to the backend automatically.
# REACT_APP_API_URL=http://localhost:5000/api   ← DO NOT SET IN DEV

# ── Dev server fixes ──────────────────────────────────────────────────────────
DANGEROUSLY_DISABLE_HOST_CHECK=true
HOST=localhost
